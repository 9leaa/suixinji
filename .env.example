# Chat / classification LLM
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Embedding model for P2 related-note search.
# If DASHSCOPE_API_KEY / EMBEDDING_BASE_URL are empty, the code falls back to
# OPENAI_API_KEY / OPENAI_BASE_URL.
DASHSCOPE_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSION=1024
